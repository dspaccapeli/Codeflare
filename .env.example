# Required: tunnel UUID (or leave blank if inferable from credentials filename)
CLOUDFLARED_TUNNEL_ID=

# Required: path to tunnel credentials JSON
CLOUDFLARED_CREDENTIALS_PATH=/Users/you/.cloudflared/<tunnel-id>.json

# Public hostname to expose OpenCode on
OPENCODE_PUBLIC_HOSTNAME=optional-subdomain.domain.com

# Local OpenCode bind host and port
OPENCODE_LISTEN_HOST=127.0.0.1
OPENCODE_PORT=4096

# Optional: hide harmless Cloudflare disconnect noise in logs
# true | false
CODEFLARE_QUIET_DISCONNECT_LOGS=false

# Optional: force-overwrite DNS route each run (destructive for existing record)
# true | false
CODEFLARE_FORCE_DNS=false
